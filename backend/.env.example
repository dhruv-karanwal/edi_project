# =================================================================
# ENVIRONMENT CONFIGURATION — Advanced Neural Machine Reading v2.0
# =================================================================

# --- LLM Settings (Google Gemini) ---
# REQUIRED: Your Google Gemini API Key. Get it from Google AI Studio.
GEMINI_API_KEY=

# Optional: Gemini model configuration (defaults are stable)
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TEMPERATURE=0.2
# GEMINI_MAX_TOKENS=2048

# --- Database Settings ---
# Defaults to a local SQLite database in the backend directory
DATABASE_URL=sqlite:///./research_rag.db
STORAGE_PATH=./storage

# --- Embedding & Retrieval Configuration ---
# SentenceTransformer model for generating text embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Number of relevant context snippets to retrieve for Gemini reasoning
TOP_K_VECTOR=5
MIN_EVIDENCE_RELEVANCE=0.25

# =================================================================
# NEW — v2.0 Advanced AI Feature Toggles
# =================================================================

# Feature 1: OpenCV OCR Enhancement Pipeline
# Set to false to skip image preprocessing (faster, but lower OCR quality on scanned PDFs)
ENABLE_OCR_PREPROCESSING=true
# Prioritise EasyOCR over Tesseract (highly recommended for Render/Docker)
PREFER_EASYOCR=true

# Feature 2: AI Layout Detection (surya-ocr)
# Set to false to fall back to legacy PyMuPDF heuristic block extraction
ENABLE_LAYOUT_DETECTION=true

# Feature 3: CLIP Visual Embeddings
# Enable CLIP image embeddings for figure/table semantic retrieval
ENABLE_CLIP=true
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=openai

# Feature 4: Hybrid BM25 + FAISS + CLIP Retrieval
# Enable multi-stage retrieval pipeline. Set false for legacy FAISS-only.
ENABLE_HYBRID_RETRIEVAL=true
# Retrieval stage weights (should sum to 1.0)
BM25_WEIGHT=0.30
FAISS_WEIGHT=0.50
CLIP_WEIGHT=0.20

# Feature 5: LayoutLMv3 Multimodal Understanding
# WARNING: Disabled by default — 900MB model, ~60s/page on CPU.
# Enable only if you have GPU or are analyzing single pages.
ENABLE_LAYOUTLM=false
LAYOUTLM_MODEL=microsoft/layoutlmv3-base
