# =================================================================
# ENVIRONMENT CONFIGURATION FOR MULTIMODAL DOCUMENT RAG WORKSPACE
# =================================================================

# --- LLM Settings (Google Gemini) ---
# REQUIRED: Your Google Gemini API Key. Get it from Google AI Studio.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model configuration (defaults are stable)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TEMPERATURE=0.2
# GEMINI_MAX_TOKENS=2048

# --- Database Settings ---
# Defaults to a local SQLite database in the backend directory
# For SQLite: sqlite:///./research_rag.db
# For PostgreSQL: postgresql://username:password@localhost:5432/db_name
DATABASE_URL=sqlite:///./research_rag.db

# --- Embedding & Retrieval Configuration ---
# SentenceTransformer model for generating text embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Number of relevant context snippets to retrieve for Gemini reasoning
TOP_K_VECTOR=5
MIN_EVIDENCE_RELEVANCE=0.25
